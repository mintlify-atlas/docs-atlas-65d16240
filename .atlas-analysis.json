{
  "projectType": "framework",
  "projectName": "Fluent PDF",
  "projectDescription": "A WordPress plugin that generates, customizes, and delivers PDF documents from form submissions and other Fluent product entries, with a hook-based extensibility system for third-party integrations.",
  "theme": "palm",
  "primaryColor": "#E05C0C",
  "lightColor": "#FFF3EC",
  "darkColor": "#7A2A00",
